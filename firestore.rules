rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ─────────────────────────────────────────────
    // 운영자 이메일 목록
    // 추가/변경 시 이 배열만 수정하고 콘솔에서 재게시.
    // ─────────────────────────────────────────────
    function adminEmails() {
      return [
        'greatosan100@gmail.com'
      ];
    }

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in adminEmails();
    }

    function nonEmptyString(v, maxLen) {
      return v is string && v.size() > 0 && v.size() <= maxLen;
    }

    // 응원 — 누구나 쓰기 가능 (필드 검증), 공개 읽기
    match /cheers/{id} {
      allow read: if true;

      allow create: if
        nonEmptyString(request.resource.data.nickname, 20)
        && request.resource.data.nickname.matches('^[a-zA-Z][a-zA-Z0-9_]{2,18}[a-zA-Z0-9]$')
        && nonEmptyString(request.resource.data.content, 100)
        && request.resource.data.reports == 0
        && request.resource.data.isHidden == false
        && request.resource.data.fromGame is bool
        && request.resource.data.createdAt is timestamp;

      allow update, delete: if isAdmin();
    }

    // 신고 — 누구나 작성, 공개 읽기 차단
    match /reports/{id} {
      allow read: if isAdmin();
      allow create: if
        nonEmptyString(request.resource.data.cheerId, 200)
        && request.resource.data.reason in ['abuse', 'spam', 'fake', 'etc']
        && request.resource.data.processed == false
        && request.resource.data.createdAt is timestamp;
      allow update, delete: if isAdmin();
    }

    // 보도자료 — 공개 읽기 (isPublished=true만), 운영자만 쓰기
    match /press/{id} {
      allow read: if resource.data.isPublished == true || isAdmin();
      allow write: if isAdmin();
    }

    // SNS 큐레이션 — 공개 읽기 (isActive=true), 운영자만 쓰기
    match /snsCuration/{id} {
      allow read: if resource.data.isActive == true || isAdmin();
      allow write: if isAdmin();
    }

    // 성과 / 공약 카드 — 공개 읽기, 운영자만 쓰기
    match /achievements/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /pledges/{id} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // 설정 — 운영자만 읽기/쓰기
    match /settings/{id} {
      allow read, write: if isAdmin();
    }

    // 그 외 경로 차단
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
