rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // ─────────────────────────────────────────────
    // 운영자 이메일 목록 (firestore.rules와 동기화)
    // ─────────────────────────────────────────────
    function adminEmails() {
      return [
        'greatosan100@gmail.com'
      ];
    }

    function isAdmin() {
      return request.auth != null
        && request.auth.token.email_verified == true
        && request.auth.token.email in adminEmails();
    }

    function isValidImageUpload() {
      return request.resource.size < 5 * 1024 * 1024
        && request.resource.contentType.matches('image/.*');
    }

    match /press/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isValidImageUpload();
    }

    match /achievements/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isValidImageUpload();
    }

    match /pledges/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isValidImageUpload();
    }

    match /sns/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin() && isValidImageUpload();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
